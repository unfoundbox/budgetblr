# Copy to .env.local and fill in. For local dev, get values from `supabase status`.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (seed script / admin tasks). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_TOKEN=

# Stadia Maps API key for Stamen Terrain tiles (free tier). Keyless on localhost;
# required for the deployed domain. Get one at https://stadiamaps.com (Public so domain-restricted).
NEXT_PUBLIC_STADIA_API_KEY=

# Google Analytics 4 measurement id (G-XXXXXXX). Leave empty to disable GA.
NEXT_PUBLIC_GA_ID=

# AI search (Ask AI). Server-only Anthropic key + public flag to enable the chat.
# Optional: ANTHROPIC_MODEL (default claude-opus-4-8; set claude-haiku-4-5 for cheaper/faster).
ANTHROPIC_API_KEY=
NEXT_PUBLIC_AI_SEARCH=
ANTHROPIC_MODEL=
